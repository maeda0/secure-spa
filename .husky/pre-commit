#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🔒 セキュリティチェック開始..."

# ESLint（ステージングファイルのみ）
npx lint-staged

# TypeScript 型チェック
echo "📝 TypeScript 型チェック..."
npx tsc --noEmit
if [ $? -ne 0 ]; then
  echo "❌ TypeScript エラーがあります。コミットを中止します。"
  exit 1
fi

# 依存関係の脆弱性チェック（high / critical のみ）
echo "🔍 依存関係の脆弱性チェック..."
npm audit --audit-level=high
if [ $? -ne 0 ]; then
  echo "⚠️  high / critical レベルの脆弱性が検出されました。"
  echo "   npm audit fix を実行するか、問題を確認してください。"
  echo "   緊急の場合は git commit --no-verify で一時スキップできますが、必ず後で対処してください。"
  exit 1
fi

echo "✅ セキュリティチェック完了"
