# ────────────────────────────────────────────────────────────
# frontend/.env.example
# このファイルをコピーして .env.local を作成してください
# .env.local は .gitignore で除外されます（コミット禁止）
# ────────────────────────────────────────────────────────────

# QC API Lambda Function URL（CDK deploy後に取得: Outputs.ApiUrl）
# 末尾スラッシュなし
VITE_API_BASE_URL=https://xxxxxxxxxx.lambda-url.ap-northeast-1.on.aws

# デフォルト表示リポジトリ（owner/repo 形式）
VITE_DEFAULT_REPO=your-github-username/your-repo-name
